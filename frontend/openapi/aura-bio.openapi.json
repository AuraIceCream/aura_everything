{
  "openapi": "3.1.0",
  "info": { "title": "AURA-Bio Local API", "version": "0.1.0" },
  "servers": [{ "url": "http://127.0.0.1:8000" }],
  "paths": {
    "/api/v1/health": { "get": { "operationId": "getHealth", "responses": { "200": { "description": "System health", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthStatus" } } } } } } },
    "/api/v1/capabilities": { "get": { "operationId": "getCapabilities", "responses": { "200": { "description": "Enabled capabilities", "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } } } } } },
    "/api/v1/corpus/status": { "get": { "operationId": "getCorpusStatus", "responses": { "200": { "description": "Corpus readiness", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CorpusStatus" } } } } } } },
    "/api/v1/runs": { "post": { "operationId": "createRun", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RunRequest" } } } }, "responses": { "202": { "description": "Run queued", "content": { "application/json": { "schema": { "type": "object", "required": ["run_id", "status"], "properties": { "run_id": { "type": "string" }, "status": { "type": "string" } } } } } } } } },
    "/api/v1/runs/{run_id}": { "get": { "operationId": "getRun", "parameters": [{ "name": "run_id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Completed or active run", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Run" } } } } } } },
    "/api/v1/runs/{run_id}/events": { "get": { "operationId": "streamRun", "parameters": [{ "name": "run_id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Server-sent RunStreamEvent sequence", "content": { "text/event-stream": { "schema": { "$ref": "#/components/schemas/RunStreamEvent" } } } } } } },
    "/api/v1/retrieval/search": { "post": { "operationId": "retrievalSearch", "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["query", "mode"], "properties": { "query": { "type": "string" }, "mode": { "$ref": "#/components/schemas/RetrievalMode" }, "source_type": { "type": ["string", "null"] } } } } }, "responses": { "200": { "description": "Ranked retrieval results", "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } } } } } } },
    "/api/v1/sessions/{session_id}": { "get": { "operationId": "getSession", "parameters": [{ "name": "session_id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Local conversation session", "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } } } } } }
  },
  "components": {
    "schemas": {
      "RetrievalMode": { "type": "string", "enum": ["bm25", "dense", "hybrid", "reranked"] },
      "HealthStatus": { "type": "object", "required": ["status", "backend", "model", "retrieval", "index_ready", "version"], "properties": { "status": { "type": "string", "enum": ["ready", "partial", "offline"] }, "backend": { "type": "boolean" }, "model": { "type": "boolean" }, "retrieval": { "type": "boolean" }, "index_ready": { "type": "boolean" }, "version": { "type": "string" } } },
      "RunRequest": { "type": "object", "required": ["query", "learner_level", "teaching_mode", "response_length", "context_depth", "source_types", "allow_external_critic"], "properties": { "query": { "type": "string", "minLength": 1 }, "learner_level": { "type": "string" }, "teaching_mode": { "type": "string" }, "response_length": { "type": "string" }, "context_depth": { "type": "string" }, "source_types": { "type": "array", "items": { "type": "string" } }, "allow_external_critic": { "type": "boolean" } } },
      "Citation": { "type": "object", "required": ["citation_id", "source_id", "source_title", "source_type", "section", "chunk_id", "excerpt", "license_id", "rank"], "properties": { "citation_id": { "type": "string" }, "source_id": { "type": "string" }, "source_title": { "type": "string" }, "source_type": { "type": "string" }, "section": { "type": "string" }, "chunk_id": { "type": "string" }, "excerpt": { "type": "string" }, "url": { "type": "string", "format": "uri" }, "license_id": { "type": "string" }, "rank": { "type": "integer" }, "dense_score": { "type": "number" }, "sparse_score": { "type": "number" }, "rerank_score": { "type": "number" } } },
      "Answer": { "type": "object", "required": ["markdown", "citations", "confidence", "confidence_rationale", "verification_status", "revised", "limitations", "latency_ms"], "properties": { "markdown": { "type": "string" }, "citations": { "type": "array", "items": { "$ref": "#/components/schemas/Citation" } }, "confidence": { "type": "string", "enum": ["high", "medium", "low"] }, "confidence_rationale": { "type": "string" }, "verification_status": { "type": "string" }, "revised": { "type": "boolean" }, "limitations": { "type": "array", "items": { "type": "string" } }, "latency_ms": { "type": "integer" } } },
      "TraceEvent": { "type": "object", "required": ["event_id", "stage", "status", "timestamp", "summary"], "properties": { "event_id": { "type": "string" }, "stage": { "type": "string" }, "status": { "type": "string" }, "timestamp": { "type": "string", "format": "date-time" }, "duration_ms": { "type": "integer" }, "model": { "type": "string" }, "token_usage": { "type": "integer" }, "api_usage": { "type": "boolean" }, "summary": { "type": "string" }, "details": { "type": "object", "additionalProperties": true }, "error": { "type": "string" } } },
      "Run": { "type": "object", "required": ["run_id", "status", "query", "request", "trace", "created_at"], "properties": { "run_id": { "type": "string" }, "status": { "type": "string" }, "query": { "type": "string" }, "request": { "$ref": "#/components/schemas/RunRequest" }, "answer": { "$ref": "#/components/schemas/Answer" }, "trace": { "type": "array", "items": { "$ref": "#/components/schemas/TraceEvent" } }, "created_at": { "type": "string", "format": "date-time" } } },
      "RunStreamEvent": { "oneOf": [{ "$ref": "#/components/schemas/TraceEvent" }, { "$ref": "#/components/schemas/Answer" }], "discriminator": { "propertyName": "type" } },
      "CorpusStatus": { "type": "object", "additionalProperties": true }
    }
  }
}
